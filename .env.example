# Environment Variables Template
# Copy this file to .env and fill in your actual values
# .env is gitignored and will not be committed to the repository
#
# Spring Boot will automatically load this file via spring-dotenv library

# Database Configuration
# For Neon (Production): Use the connection string from Neon dashboard
# DATABASE_URL=jdbc:postgresql://username:password@ep-xyz.us-east-2.aws.neon.tech/invoiceme?sslmode=require

# For Local Docker (Development): Use Docker Compose connection
DATABASE_URL=jdbc:postgresql://localhost:5432/invoiceme?user=invoiceme&password=invoiceme

# JWT Configuration (REQUIRED)
# Generate a secure secret key (minimum 256 bits / 32 characters)
# You can generate one using: openssl rand -base64 32
# The application will fail to start if this is not set
JWT_SECRET=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32

# Server Configuration (optional)
# PORT=8080

# Production URLs (for local testing, optional)
# RENDER_DEPLOY_HOOK_URL=your-render-deploy-hook-url
